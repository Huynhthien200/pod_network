{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd react-privy-example && npm install",
  "buildCommand": "cd react-privy-example && npm run build",
  "outputDirectory": "react-privy-example/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
